pin "PA00" {
    default-pull "down"
    supports "gpio" { any; }
    supports "lcdc" "spi" { rstb; }
    supports "usart" { tx; rx; cts; rts; }
    supports "i2c" { sda; scl; }
    supports "gptim" { ch1; ch2; ch3; ch4; etr; }
    supports "lptim" { in; out; etr; }
    supports "atim" { ch1; ch2; ch3; ch4; ch1n; ch2n; ch3n; bk; bk2; etr; }
    supports "lcdc" "8080" { rstb; }
}

